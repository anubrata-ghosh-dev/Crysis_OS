# Firebase Configuration (Required for real-time incident tracking)
# Get these values from Firebase Console: Project Settings > Web App > SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# OpenAI API Configuration (Optional)
OPENAI_API_KEY=your_key_here

# Map Configuration (optional, for external maps)
NEXT_PUBLIC_MAP_CENTER_LAT=40.7505
NEXT_PUBLIC_MAP_CENTER_LNG=-73.9972
NEXT_PUBLIC_MAP_ZOOM=12
